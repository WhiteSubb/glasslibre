-- ────────────────────────────────────────────────────────────
--  HELPERS
-- ────────────────────────────────────────────────────────────
local function tw(obj, props, t)
    TweenSvc:Create(obj,
        TweenInfo.new(t or T.Speed, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        props):Play()
end

local function New(cls, props)
    local inst = Instance.new(cls)
    for k, v in pairs(props) do
        if k ~= "Parent" then pcall(function() inst[k] = v end) end
    end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

local function Corner(p, r)
    New("UICorner", { CornerRadius = r or T.CornerMd, Parent = p })
end

local function Pad(p, top, bot, left, right)
    New("UIPadding", {
        PaddingTop    = UDim.new(0, top   or 0),
        PaddingBottom = UDim.new(0, bot   or 0),
        PaddingLeft   = UDim.new(0, left  or 0),
        PaddingRight  = UDim.new(0, right or 0),
        Parent = p,
    })
end

local function VList(p, gap)
    New("UIListLayout", {
        FillDirection = Enum.FillDirection.Vertical,
        Padding       = UDim.new(0, gap or 0),
        SortOrder     = Enum.SortOrder.LayoutOrder,
        Parent        = p,
    })
end

local function Ripple(host)
    local rip = New("Frame", {
        Size = UDim2.new(0,0,0,0), AnchorPoint = Vector2.new(0.5,0.5),
        Position = UDim2.new(0.5,0,0.5,0),
        BackgroundColor3 = Color3.new(1,1,1), BackgroundTransparency = 0.80,
        ZIndex = (host.ZIndex or 1) + 10, Parent = host,
    })
    New("UICorner", { CornerRadius = UDim.new(1,0), Parent = rip })
    tw(rip, { Size = UDim2.new(2,0,2,0), BackgroundTransparency = 1 }, 0.35)
    task.delay(0.40, function() if rip and rip.Parent then rip:Destroy() end end)
end

-- ────────────────────────────────────────────────────────────
--  PLAIN DRAG
-- ────────────────────────────────────────────────────────────
local function Drag(handle, target)
    local dragging = false
    local startPos, startMouse

    handle.InputBegan:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseButton1
        and i.UserInputType ~= Enum.UserInputType.Touch then return end
        dragging   = true
        startMouse = Vector2.new(i.Position.X, i.Position.Y)
        -- Convert current position to pure offset using AbsolutePosition
        -- then immediately lock the window to that offset so scale is gone
        local ap = target.AbsolutePosition
        target.Position = UDim2.fromOffset(ap.X, ap.Y)
        startPos = Vector2.new(ap.X, ap.Y)
    end)

    handle.InputEnded:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseButton1
        and i.UserInputType ~= Enum.UserInputType.Touch then return end
        dragging = false
    end)

    UIS.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType ~= Enum.UserInputType.MouseMovement
        and i.UserInputType ~= Enum.UserInputType.Touch then return end
        local d = Vector2.new(i.Position.X, i.Position.Y) - startMouse
        target.Position = UDim2.fromOffset(startPos.X + d.X, startPos.Y + d.Y)
    end)

    return function() end
end

-- ────────────────────────────────────────────────────────────
--  SCROLL FRAME  (flat, no card bg)
-- ────────────────────────────────────────────────────────────
-- Registry so scroll frames can close any open dropdown
local scrollCloseCallbacks = {}
local function registerDropdownClose(fn)
    table.insert(scrollCloseCallbacks, fn)
end
local function fireScrollClose()
    for _, fn in ipairs(scrollCloseCallbacks) do pcall(fn) end
end

local function MakeScroll(parent)
    local sf = New("ScrollingFrame", {
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Color3.fromRGB(69, 69, 69),
        ScrollingDirection = Enum.ScrollingDirection.Y,
        CanvasSize = UDim2.new(0,0,0,0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = parent,
    })
    -- Close any open dropdown when user scrolls
    sf:GetPropertyChangedSignal("CanvasPosition"):Connect(fireScrollClose)
    Pad(sf, 8, 14, 0, 0)
    VList(sf, 0)
    return sf
end


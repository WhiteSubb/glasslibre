    local clearDragBase = Drag(TopBar, Win)

    -- ── Minimize ───────────────────────────────────────────────
    local minimized = false
    local miniSize  = UDim2.new(0, winSize.X.Offset, 0, BAR_H)
    local fullSize  = winSize

    local function setMinimized(v)
        minimized = v
        fireScrollClose()  -- close any open dropdown
        clearDragBase()
        if v then
            Body.Visible = false
            tw(Win, { Size = miniSize }, 0.20)
        else
            tw(Win, { Size = fullSize }, 0.22)
            task.delay(0.22, function()
                if not minimized then Body.Visible = true end
            end)
        end
    end

    MinBtn.MouseButton1Click:Connect(function()
        setMinimized(not minimized)
    end)
    TopBar.InputBegan:Connect(function(i)
        if i.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        if not minimized then return end
        local startX, startY = i.Position.X, i.Position.Y
        local moved = false
        local mc = UIS.InputChanged:Connect(function(i2)
            if i2.UserInputType == Enum.UserInputType.MouseMovement then
                if math.abs(i2.Position.X - startX) > 4
                or math.abs(i2.Position.Y - startY) > 4 then
                    moved = true
                end
            end
        end)
        local ec ec = UIS.InputEnded:Connect(function(i2)
            if i2.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
            mc:Disconnect(); ec:Disconnect()
            if not moved then setMinimized(false) end
        end)
    end)

    local W = { _tabs={}, _active=nil, _vis=true }

    UIS.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.KeyCode == togKey then W:Toggle() end
    end)

    function W:Toggle()
        fireScrollClose()
        self._vis = not self._vis
        Win.Visible = self._vis
    end

    function W:Destroy() SG:Destroy() end
    function W:Notify(c) PushNotif(c) end

    function W:_Activate(tabObj)
        fireScrollClose()  -- close any open dropdown
        for _,t in ipairs(self._tabs) do
            tw(t.btn, { BackgroundColor3=Color3.fromRGB(69, 69, 69), BackgroundTransparency=1 })
            tw(t.bar, { BackgroundTransparency=1 })
            tw(t.lbl, { TextTransparency=0.55 })
            tw(t.ico, { ImageTransparency=0.55 })
            t.page.Visible = false
        end
        tw(tabObj.btn, { BackgroundColor3=T.TabActiveBg, BackgroundTransparency=T.TabActiveTrans })
        tw(tabObj.bar, { BackgroundTransparency=0 })
        tw(tabObj.lbl, { TextTransparency=0 })
        tw(tabObj.ico, { ImageTransparency=0 })
        tabObj.page.Visible = true
        self._active = tabObj
        PageTitle.Text = tabObj.name
    end


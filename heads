        Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,0,42),
        BackgroundColor3=Color3.new(1,1,1), BackgroundTransparency=0.88,
        BorderSizePixel=0, ZIndex=3, Parent=ContentArea,
    })

    -- Page container
    local PageCont = New("Frame", {
        Name="Pages", Size=UDim2.new(1,0,1,-44), Position=UDim2.new(0,0,0,44),
        BackgroundTransparency=1, ClipsDescendants=true, ZIndex=2, Parent=ContentArea,
    })


local notifGui, notifStack = nil, {}
local NW, NH, NG = 240, 68, 6

local function ensureNotifGui()
    if notifGui and notifGui.Parent then return end
    notifGui = New("ScreenGui", {
        Name="GlassUI_Notifs", ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset=true, DisplayOrder=50,
    })
    local ok = pcall(function() notifGui.Parent = CoreGui end)
    if not ok then notifGui.Parent = LP:WaitForChild("PlayerGui") end
end

local function restack()
    for i,f in ipairs(notifStack) do
        tw(f, { Position=UDim2.new(1,-(NW+12),1,-(i*(NH+NG))) }, 0.2)
    end
end

local function PushNotif(cfg)
    ensureNotifGui()
    cfg = cfg or {}
    local title = cfg.Title   or "Notification"
    local msg   = cfg.Message or ""
    local dur   = cfg.Duration or 3.5
    local ac    = ({info=T.Info,success=T.Success,error=T.Danger,warning=T.Warning})[cfg.Type or "info"] or T.Info

    local frame = New("Frame", {
        Size=UDim2.new(0,NW,0,NH),
        Position=UDim2.new(1,NW+20,1,-NH),
        BackgroundColor3=Color3.fromRGB(69, 69, 69),
        BackgroundTransparency=0.40,
        BorderSizePixel=0, ZIndex=200, Parent=notifGui,
    })
    Corner(frame, T.CornerMd)

    New("Frame", {
        Size=UDim2.new(0,3,0.65,0), Position=UDim2.new(0,0,0.175,0),
        BackgroundColor3=ac, BorderSizePixel=0, ZIndex=201, Parent=frame,
    })
    New("TextLabel", {
        Size=UDim2.new(1,-22,0,18), Position=UDim2.new(0,12,0,10),
        BackgroundTransparency=1, Text=title, TextColor3=Color3.new(1,1,1),
        TextSize=13, Font=T.FontBold, TextXAlignment=Enum.TextXAlignment.Left,
        ZIndex=202, Parent=frame,
    })
    New("TextLabel", {
        Size=UDim2.new(1,-22,0,26), Position=UDim2.new(0,12,0,30),
        BackgroundTransparency=1, Text=msg, TextColor3=Color3.new(1,1,1),
        TextTransparency=0.3, TextSize=11, Font=T.Font, TextWrapped=true,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=202, Parent=frame,
    })
    local prog = New("Frame", {
        Size=UDim2.new(1,0,0,2), Position=UDim2.new(0,0,1,-2),
        BackgroundColor3=ac, BorderSizePixel=0, ZIndex=202, Parent=frame,
    })
    local xBtn = New("TextButton", {
        Size=UDim2.new(0,16,0,16), Position=UDim2.new(1,-20,0,8),
        BackgroundTransparency=1, Text="✕", TextColor3=Color3.new(1,1,1),
        TextTransparency=0.4, TextSize=9, Font=T.FontBold, ZIndex=203, Parent=frame,
    })

    table.insert(notifStack, 1, frame)
    restack()
    tw(prog, { Size=UDim2.new(0,0,0,2) }, dur)

    local function dismiss()
        local idx=table.find(notifStack,frame)
        if idx then table.remove(notifStack,idx) end
        tw(frame, { Position=UDim2.new(1,NW+20,frame.Position.Y.Scale,frame.Position.Y.Offset) }, 0.2)
        task.delay(0.25, function() if frame and frame.Parent then frame:Destroy() end restack() end)
    end
    xBtn.MouseButton1Click:Connect(dismiss)
    task.delay(dur, dismiss)
end


        name = name or ("Tab"..#self._tabs+1)
        icon = icon or ""

        local imgUrl = icon
        if imgUrl:match("^rbxassetid://") then
            local id = imgUrl:match("rbxassetid://(%d+)")
            if id then imgUrl = "rbxthumb://type=Asset&id="..id.."&w=420&h=420" end
        end

        local btn = New("TextButton", {
            Name="Tab_"..name,
            Size=UDim2.new(1,0,0,46),
            BackgroundColor3=Color3.fromRGB(69, 69, 69),
            BackgroundTransparency=1,
            Text="", BorderSizePixel=0, AutoButtonColor=false,
            ZIndex=4, Parent=TabList,
